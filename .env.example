# elva-server 环境配置模板
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_PORT=3000
NODE_ENV=development

# CloudBase 环境配置
CLOUDBASE_ENV_ID=cloud1-0gfwfzyh9c423958

# 数据库配置
# 本地开发
DATABASE_URL="mysql://root:password@localhost:3306/nexus"

# 微信云开发 MySQL（生产环境）
# 用户名: admin
# 数据库名: nexus
DATABASE_URL="mysql://admin:database123245678.@172.17.0.13:3306/nexus"

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# 微信小程序配置 (可选)
WECHAT_APPID=""
WECHAT_SECRET=""

# Redis 配置 (可选)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""