# elva-server 环境配置模板
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_PORT=3000
NODE_ENV=development

# 数据库配置
DATABASE_URL="mysql://user:password@localhost:3306/elva"

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# 微信小程序配置 (可选)
WECHAT_APPID=""
WECHAT_SECRET=""

# Redis 配置 (可选)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""