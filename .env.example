# elva-server 环境配置模板
# 复制此文件为 .env 并填写实际值

# 应用配置
APP_PORT=3000
NODE_ENV=development

# 数据库配置
# 本地开发
DATABASE_URL="mysql://user:password@localhost:3306/nexus"

# 微信云开发 MySQL（生产环境）
# DATABASE_URL="mysql://用户名:密码@数据库地址:端口/nexus?ssl=true"

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-at-least-32-chars"
JWT_EXPIRES_IN="7d"

# 微信小程序配置 (可选)
WECHAT_APPID=""
WECHAT_SECRET=""

# Redis 配置 (可选)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""

# CloudBase 配置（生产环境）
# CLOUDBASE_ENV_ID="env-xxxxxx"