// Prisma Schema - elva-server
// 陪玩公会管理系统数据模型

generator client {
  provider      = "prisma-client-js"
  engineType    = "library"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户 ====================
model User {
  id        BigInt   @id @default(autoincrement())
  phone     String   @unique @db.VarChar(20)
  password  String   @db.VarChar(200)
  nickname  String?  @db.VarChar(50)
  avatar    String?  @db.VarChar(500)
  status    Int      @default(1) @db.TinyInt // 1正常 2禁用
  openid    String?  @db.VarChar(64) // 微信云开发 OpenID
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clubMembers ClubMember[]
  reports     Report[]     @relation("ReportCreator")
  approvals   Report[]     @relation("ReportApprover")
  salaries    Salary[]     @relation("SalaryPayer")

  @@map("user")
}

// ==================== 俱乐部 ====================
model Club {
  id          BigInt   @id @default(autoincrement())
  name        String   @db.VarChar(100)
  logo        String?  @db.VarChar(500)
  description String?  @db.Text
  ownerId     BigInt   @map("owner_id")
  status      Int      @default(1) @db.TinyInt // 1正常 2禁用
  ext         Json?    // 扩展字段（预留）
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  members  ClubMember[]
  projects Project[]
  reports  Report[]
  earnings Earning[]
  salaries Salary[]

  @@map("club")
}

// ==================== 俱乐部成员 ====================
model ClubMember {
  id       BigInt   @id @default(autoincrement())
  clubId   BigInt   @map("club_id")
  userId   BigInt   @map("user_id")
  // 角色: 1创始人 2管理员 3成员 (预留4=组长)
  role     Int      @default(3) @db.TinyInt
  // 状态: 1正常 2待审核 3已退出
  status   Int      @default(1) @db.TinyInt
  groupId  String?  @map("group_id") @db.VarChar(64) // 预留：所属组
  ext      Json?    // 扩展字段（预留）
  joinedAt DateTime @default(now()) @map("joined_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club Club @relation(fields: [clubId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([clubId, userId])
  @@map("club_member")
}

// ==================== 项目 ====================
model Project {
  id              BigInt   @id @default(autoincrement())
  clubId          BigInt   @map("club_id")
  name            String   @db.VarChar(100)
  // 类型: 1游戏 2礼物
  type            Int      @default(1) @db.TinyInt
  price           Decimal  @db.Decimal(10, 2)
  // 价格类型: 1按时长 2按次
  priceType       Int      @default(1) @map("price_type") @db.TinyInt
  // 抽成类型: 1固定金额 2比例
  commissionType  Int      @default(1) @map("commission_type") @db.TinyInt
  commissionValue Decimal  @default(0) @map("commission_value") @db.Decimal(10, 2)
  // 状态: 1启用 2禁用
  status          Int      @default(1) @db.TinyInt
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  club    Club     @relation(fields: [clubId], references: [id])
  reports Report[]

  @@map("project")
}

// ==================== 报备 ====================
model Report {
  id           BigInt    @id @default(autoincrement())
  clubId       BigInt    @map("club_id")
  memberId     BigInt    @map("member_id")
  projectId    BigInt    @map("project_id")
  duration     Int?      // 时长（分钟）
  quantity     Int?      // 数量
  bossName     String    @map("boss_name") @db.VarChar(50)
  amount       Decimal   @default(0) @db.Decimal(10, 2)
  commission   Decimal   @default(0) @db.Decimal(10, 2)
  actualAmount Decimal   @default(0) @map("actual_amount") @db.Decimal(10, 2)
  // 状态: 1待审批 2已通过 3已驳回 4已撤销
  status       Int       @default(1) @db.TinyInt
  remark       String?   @db.VarChar(500)
  // 预留：审批流配置ID
  approvalFlowId String? @map("approval_flow_id") @db.VarChar(64)
  // 预留：规则引擎ID
  ruleId       String?   @map("rule_id") @db.VarChar(64)
  ext          Json?     // 扩展字段（预留）
  createdBy    BigInt    @map("created_by")
  approvedBy   BigInt?   @map("approved_by")
  approvedAt   DateTime? @map("approved_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  club     Club     @relation(fields: [clubId], references: [id])
  project  Project  @relation(fields: [projectId], references: [id])
  creator  User     @relation("ReportCreator", fields: [createdBy], references: [id])
  approver User?    @relation("ReportApprover", fields: [approvedBy], references: [id])
  earnings Earning[]

  @@map("report")
}

// ==================== 收入明细 ====================
model Earning {
  id       BigInt   @id @default(autoincrement())
  clubId   BigInt   @map("club_id")
  memberId BigInt   @map("member_id")
  reportId BigInt?  @map("report_id")
  // 类型: 1收入 2返点 3扣减
  type     Int      @default(1) @db.TinyInt
  amount   Decimal  @db.Decimal(10, 2)
  // 状态: 1待发放 2已发放 3已取消
  status   Int      @default(1) @db.TinyInt
  salaryId BigInt?  @map("salary_id")
  remark   String?  @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  club   Club    @relation(fields: [clubId], references: [id])
  report Report? @relation(fields: [reportId], references: [id])
  salary Salary? @relation(fields: [salaryId], references: [id])

  @@map("earning")
}

// ==================== 工资 ====================
model Salary {
  id              BigInt    @id @default(autoincrement())
  clubId          BigInt    @map("club_id")
  memberId        BigInt    @map("member_id")
  periodStart     DateTime  @map("period_start") @db.Date
  periodEnd       DateTime  @map("period_end") @db.Date
  totalAmount     Decimal   @default(0) @map("total_amount") @db.Decimal(10, 2)
  totalCommission Decimal   @default(0) @map("total_commission") @db.Decimal(10, 2)
  actualAmount    Decimal   @default(0) @map("actual_amount") @db.Decimal(10, 2)
  // 状态: 1待发放 2发放中 3已发放
  status          Int       @default(1) @db.TinyInt
  remark          String?   @db.VarChar(500)
  paidBy          BigInt?   @map("paid_by")
  paidAt          DateTime? @map("paid_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  club     Club      @relation(fields: [clubId], references: [id])
  payer    User?     @relation("SalaryPayer", fields: [paidBy], references: [id])
  earnings Earning[]

  @@map("salary")
}

// ==================== 钱包 ====================
model Wallet {
  id        BigInt   @id @default(autoincrement())
  clubId    BigInt   @map("club_id")
  userId    BigInt   @map("user_id")
  balance   Decimal  @default(0) @db.Decimal(10, 2) // 可用余额
  frozen    Decimal  @default(0) @db.Decimal(10, 2) // 冻结金额
  // 状态: 1正常 2冻结
  status    Int      @default(1) @db.TinyInt
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  transactions WalletTransaction[]

  @@unique([clubId, userId])
  @@map("wallet")
}

// ==================== 钱包交易记录 ====================
model WalletTransaction {
  id         BigInt   @id @default(autoincrement())
  walletId   BigInt   @map("wallet_id")
  // 类型: 1充值 2代扣 3退款 4提现 5调账增加 6调账减少
  type       Int      @db.TinyInt
  amount     Decimal  @db.Decimal(10, 2)
  balance    Decimal  @db.Decimal(10, 2) // 交易后余额
  // 状态: 1成功 2失败 3处理中
  status     Int      @default(1) @db.TinyInt
  relateId   BigInt?  @map("relate_id") // 关联ID（报备ID/工资ID等）
  relateType String?  @map("relate_type") @db.VarChar(50) // 关联类型
  remark     String?  @db.VarChar(500)
  createdBy  BigInt?  @map("created_by") // 操作人
  createdAt  DateTime @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@map("wallet_transaction")
}

// ==================== 俱乐部配置 ====================
model ClubConfig {
  id                    BigInt   @id @default(autoincrement())
  clubId                BigInt   @unique @map("club_id")
  // 积分设置
  autoDeduct            Boolean  @default(false) @map("auto_deduct") // 自动代扣开关
  minBalance            Decimal  @default(0) @map("min_balance") @db.Decimal(10, 2) // 最低余额门槛
  // 审批设置
  approvalMode          Int      @default(1) @map("approval_mode") @db.TinyInt // 1仅通知 2所属人 3管理员 4双签
  // 提现设置
  withdrawFeeRate       Decimal  @default(0) @map("withdraw_fee_rate") @db.Decimal(5, 4) // 提现手续费率
  minWithdrawAmount     Decimal  @default(100) @map("min_withdraw_amount") @db.Decimal(10, 2) // 最低提现金额
  // 其他设置
  ext                   Json?
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("club_config")
}
